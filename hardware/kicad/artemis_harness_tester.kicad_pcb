  ;; ---------------------------------------------------------------------------
  ;; Mounting holes
  ;; ---------------------------------------------------------------------------
  (footprint "MountingHole:MountingHole_3.2mm" (layer "F.Cu")
    (at 5 5)
    (attr through_hole)
    (fp_text reference "H1" (at 0 -3) (layer "F.SilkS"))
