  (gr_line (start 0 0) (end 140 0) (layer "Edge.Cuts") (width 0.1))
  (gr_line (start 140 0) (end 140 70) (layer "Edge.Cuts") (width 0.1))
  (gr_line (start 140 70) (end 0 70) (layer "Edge.Cuts") (width 0.1))
  (gr_line (start 0 70) (end 0 0) (layer "Edge.Cuts") (width 0.1))

